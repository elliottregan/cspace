# OS
.DS_Store

# Editor
.idea/
.vscode/
*.swp
*.swo

# Agent supervisor — node_modules is installed inside the container at build time
lib/agent-supervisor/node_modules/
lib/agent-supervisor-bun/node_modules/

# Per-machine config override only — .cspace/ is otherwise tracked. In
# particular, .cspace/memory/ is the project-shared Claude Code memory
# and MUST stay in git (see CLAUDE.md "Agent memory"). Do not blanket-
# ignore .cspace/.
.cspace.local.json

.env
.pnpm-store/

# Local per-machine search config override. Root search.yaml is for local
# sidecar URL overrides; embedded default.yaml holds the real defaults.
/search.yaml

# Runtime index status file — written by cspace search index, not source.
.cspace/search-index-status.json

# Go build artifacts
bin/cspace-go
bin/cspace-go-linux-amd64
bin/cspace-go-linux-arm64
bin/cspace-linux
bin/cspace-linux-arm64
bin/cspace-search
bin/cspace-search-mcp
bin/cspace-registry-daemon
dist/

# The Phase 0 Bun supervisor binary lives under lib/agent-supervisor-bun/dist/
# and is COPYed into the prototype image. We track the file (Task 3 ships a
# stub; Task 4 replaces it with the compiled Bun binary) so the image build
# works on a fresh clone. Override the global `dist/` ignore here.
!lib/agent-supervisor-bun/dist/
!lib/agent-supervisor-bun/dist/cspace-supervisor

# Embedded assets (generated from lib/ by make sync-embedded).
# .gitkeep is tracked so `go:embed all:embedded` has at least one match
# on fresh checkouts — without it, `go vet` / `go build` fail before
# `make sync-embedded` has ever run.
internal/assets/embedded/*
!internal/assets/embedded/.gitkeep
.claude/settings.local.json
