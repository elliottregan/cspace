# OS
.DS_Store

# Editor
.idea/
.vscode/
*.swp
*.swo

# Agent supervisor — node_modules is installed inside the container at build time
lib/agent-supervisor/node_modules/
.cspace.local.json

.env
.pnpm-store/

# Go build artifacts
bin/cspace-go
bin/cspace-go-linux-amd64
bin/cspace-go-linux-arm64
bin/cspace-linux
dist/

# Embedded assets (generated from lib/ by make sync-embedded).
# .gitkeep is tracked so `go:embed all:embedded` has at least one match
# on fresh checkouts — without it, `go vet` / `go build` fail before
# `make sync-embedded` has ever run.
internal/assets/embedded/*
!internal/assets/embedded/.gitkeep
