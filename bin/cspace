#!/usr/bin/env bash
# cspace — Portable CLI for managing Claude Code devcontainer instances
set -euo pipefail

# Resolve CSPACE_HOME from symlinks
CSPACE_HOME="${CSPACE_HOME:-$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")/.." && pwd)}"
export CSPACE_HOME

# Source core libraries
# shellcheck source=../lib/core/config.sh
source "$CSPACE_HOME/lib/core/config.sh"
# shellcheck source=../lib/core/ports.sh
source "$CSPACE_HOME/lib/core/ports.sh"
# shellcheck source=../lib/core/instance.sh
source "$CSPACE_HOME/lib/core/instance.sh"
# shellcheck source=../lib/core/compose.sh
source "$CSPACE_HOME/lib/core/compose.sh"
# shellcheck source=../lib/core/supervisor.sh
source "$CSPACE_HOME/lib/core/supervisor.sh"

VERSION="0.1.0"

# ─── Helpers ────────────────────────────────────────────────────────

usage() {
    cat <<'EOF'
cspace — Portable CLI for managing Claude Code devcontainer instances

USAGE:
  cspace                              Interactive TUI menu
  cspace <command> [args] [flags]

INSTANCE MANAGEMENT:
  cspace up [name|branch]             Create/reconnect instance + launch Claude
  cspace up --no-claude [name]        Create instance without launching Claude
  cspace ssh <name>                   Shell into running instance
  cspace list                         List running instances for this project
  cspace list --all                   List instances across ALL projects
  cspace ports <name>                 Show port mappings
  cspace down <name>                  Destroy instance + volumes
  cspace down --all                   Destroy this project's instances + shared services
  cspace down --everywhere            Destroy ALL cspace instances across ALL projects
  cspace warm <name...>               Pre-provision containers
  cspace rebuild                      Rebuild container image

AUTONOMOUS AGENTS:
  cspace up <name> --prompt-file <path>   One-shot agent with a free-text prompt
  cspace coordinate "<instructions>"      Multi-task coordinator (reads coordinator.md playbook)
  cspace coordinate --prompt-file <path>  Same, prompt loaded from file (no quoting)
  cspace coordinate --name <name> ...     Use a specific instance name (resumable)

SUPERVISOR (host-side dispatch to running agents):
  cspace send <instance> "text"           Inject a user turn into a session
  cspace respond <instance> <qid> "text"  Reply to an agent's question
  cspace ask                              List pending agent questions
  cspace ask <instance>                   List pending questions for one instance
  cspace watch [instance]                 Stream agent notifications/questions
  cspace interrupt <instance>             Interrupt a running session
  cspace agent-status <instance>          Show supervisor status JSON
  cspace restart-supervisor <instance>    Restart agent supervisor (preserves workspace)
    [--reason "text"]                     Why the restart is needed

PROJECT SETUP:
  cspace init                         Scaffold .cspace.json + .cspace/
  cspace init --full                  Also copy all templates for customization

OTHER:
  cspace sync-context                 Generate milestone context doc
  cspace self-update                  Update cspace to latest version
  cspace version                      Show version
  cspace help                         Show this help
EOF
}

die() { echo "ERROR: $*" >&2; exit 1; }

# ─── Commands ───────────────────────────────────────────────────────

cmd_version() {
    echo "cspace $VERSION"
}

cmd_init() {
    local full=false
    [ "${1:-}" = "--full" ] && full=true

    local project_root
    project_root=$(find_project_root) || die "Not in a git repository."
    export PROJECT_ROOT="$project_root"

    if [ -f "$project_root/.cspace.json" ]; then
        echo "Project already initialized (.cspace.json exists)."
        echo "Edit .cspace.json directly to update configuration."
        return 0
    fi

    # Auto-detect project info
    local name repo prefix
    name=$(basename "$project_root")
    repo=$(git -C "$project_root" remote get-url origin 2>/dev/null | sed 's|.*github.com[:/]||; s|\.git$||' || true)
    prefix=$(echo "$name" | head -c 2)

    # Interactive config if gum is available
    if command -v gum &>/dev/null; then
        name=$(gum input --value "$name" --header "Project name") || true
        repo=$(gum input --value "$repo" --header "GitHub repo (owner/repo)") || true
        prefix=$(gum input --value "$prefix" --header "Label prefix (2-3 chars)") || true

        local firewall_domains=""
        firewall_domains=$(gum input --placeholder "api.example.com, cdn.example.com" --header "Extra firewall domains (comma-separated, optional)") || true

        local verify_all=""
        verify_all=$(gum input --placeholder "npm run lint && npm run test" --header "Verification command") || true

        local verify_e2e=""
        verify_e2e=$(gum input --placeholder "npm run e2e" --header "E2E test command (optional)") || true
    else
        echo "Tip: Install gum (https://github.com/charmbracelet/gum) for interactive setup."
        echo "Using auto-detected defaults..."
        local firewall_domains="" verify_all="" verify_e2e=""
    fi

    # Build domains array
    local domains_json="[]"
    if [ -n "$firewall_domains" ]; then
        domains_json=$(echo "$firewall_domains" | tr ',' '\n' | sed 's/^ *//;s/ *$//' | jq -R . | jq -s .)
    fi

    # Write .cspace.json
    jq -n \
        --arg name "$name" \
        --arg repo "$repo" \
        --arg prefix "$prefix" \
        --argjson domains "$domains_json" \
        --arg verify_all "$verify_all" \
        --arg verify_e2e "$verify_e2e" \
        '{
            project: { name: $name, repo: $repo, prefix: $prefix },
            container: { ports: {}, environment: {} },
            firewall: { enabled: true, domains: $domains },
            claude: { model: "claude-opus-4-6[1m]", effort: "max" },
            verify: { all: $verify_all, e2e: $verify_e2e },
            agent: { issue_label: "ready" },
            services: "",
            post_setup: ""
        }' > "$project_root/.cspace.json"

    echo "Created .cspace.json"

    # Create .cspace/ directory
    mkdir -p "$project_root/.cspace"
    echo "Created .cspace/"

    # Add .cspace.local.json to gitignore
    if [ -f "$project_root/.gitignore" ]; then
        if ! grep -q '.cspace.local.json' "$project_root/.gitignore"; then
            echo '.cspace.local.json' >> "$project_root/.gitignore"
            echo "Added .cspace.local.json to .gitignore"
        fi
    fi

    # If --full, copy all templates
    if [ "$full" = true ]; then
        echo "Copying templates for customization..."
        cp "$CSPACE_HOME/lib/templates/Dockerfile" "$project_root/.cspace/Dockerfile"
        cp "$CSPACE_HOME/lib/templates/docker-compose.core.yml" "$project_root/.cspace/docker-compose.core.yml"
        mkdir -p "$project_root/.cspace/agents"
        cp "$CSPACE_HOME/lib/agents/implementer.md" "$project_root/.cspace/agents/implementer.md"
        cp "$CSPACE_HOME/lib/agents/coordinator.md" "$project_root/.cspace/agents/coordinator.md"
        echo "Templates copied to .cspace/ — edit them to customize."
    fi

    echo ""
    echo "Project initialized! Next steps:"
    echo "  1. Edit .cspace.json to configure ports, verify commands, etc."
    echo "  2. (Optional) Add project services in .cspace/docker-compose.yml"
    echo "  3. (Optional) Add post-setup script in .cspace/post-setup.sh"
    echo "  4. Run 'cspace up' to launch an instance"
}

cmd_up() {
    local no_claude=false
    local arg=""
    local prompt=""
    local prompt_file=""
    local base_override=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --no-claude) no_claude=true; shift ;;
            --prompt) prompt="$2"; shift 2 ;;
            --prompt-file) prompt_file="$2"; shift 2 ;;
            --base) base_override="$2"; shift 2 ;;
            *) arg="$1"; shift ;;
        esac
    done

    if [ -n "$prompt" ] && [ -n "$prompt_file" ]; then
        die "--prompt and --prompt-file are mutually exclusive"
    fi
    if [ -n "$prompt_file" ] && [ ! -f "$prompt_file" ]; then
        die "Prompt file not found: $prompt_file"
    fi

    load_config
    require_initialized

    local name="" branch=""

    if [ -z "$arg" ]; then
        name=$(next_planet)
        echo "Instance name: $name"
    elif [[ "$arg" == */* ]]; then
        branch="$arg"
        name=$(echo "$arg" | tr '/' '-')
        echo "Branch: $branch -> instance: $name"
    else
        name="$arg"
    fi

    # --base overrides any branch derived from the positional arg
    [ -n "$base_override" ] && branch="$base_override"

    # Provision the instance
    CSPACE_INSTANCE_NAME="$name" CSPACE_INSTANCE_BRANCH="${branch:-}" \
        bash "$(resolve_script setup-instance.sh)"

    skip_onboarding "$name"
    show_ports "$name"

    # Git operations
    dc_exec "$name" git fetch --prune --quiet 2>/dev/null || true
    if [ -n "$branch" ]; then
        dc_exec "$name" git checkout "$branch" 2>/dev/null \
            || dc_exec "$name" git checkout -b "$branch" "origin/$branch" 2>/dev/null || true
        dc_exec "$name" git reset --hard "origin/$branch" 2>/dev/null || true
    else
        dc_exec "$name" git pull --ff-only --quiet 2>/dev/null || true
    fi

    if [ "$no_claude" = true ]; then
        echo "Instance '$name' is ready. Run 'cspace ssh $name' to connect."
        return 0
    fi

    # Launch Claude
    if [ -z "$prompt_file" ] && [ -z "$prompt" ]; then
        # Interactive TTY — drop the user straight into a live claude session.
        # Not routed through the supervisor because it has no streaming-input
        # mode appropriate for a TTY and the user is already in the loop.
        exec docker compose -p "$name" exec -u dev -w /workspace devcontainer claude --dangerously-skip-permissions
    fi

    # Autonomous path — stage the prompt in the container, then run through
    # the supervisor so both implementer and coordinator share the same
    # launch pipeline (messenger MCP tools, Unix control socket, inbox
    # watcher, structured event log). See lib/core/supervisor.sh.
    if [ -n "$prompt_file" ]; then
        # Copy the file directly — bypasses any quoting issues with the prompt body
        $DC cp "$prompt_file" devcontainer:/tmp/claude-prompt.txt
        $DC exec -T devcontainer chown dev:dev /tmp/claude-prompt.txt </dev/null
    else
        printf '%s' "$prompt" | $DC exec -T -u dev devcontainer bash -c 'cat > /tmp/claude-prompt.txt'
    fi

    local model effort
    model=$(cfg '.claude.model')
    effort=$(cfg '.claude.effort')

    local effort_flag system_prompt_flag
    effort_flag=$(build_effort_flag "$effort")
    system_prompt_flag=$(build_system_prompt_flag "$name" agent)

    launch_supervisor "$name" agent /tmp/claude-prompt.txt /tmp/agent-stderr.log "$effort_flag" "$system_prompt_flag"
}

cmd_coordinate() {
    local prompt="" prompt_file="" name=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --prompt-file) prompt_file="$2"; shift 2 ;;
            --name) name="$2"; shift 2 ;;
            --*) die "Unknown flag: $1" ;;
            *)
                if [ -z "$prompt" ]; then
                    prompt="$1"
                fi
                shift
                ;;
        esac
    done

    if [ -z "$prompt" ] && [ -z "$prompt_file" ]; then
        die "Usage: cspace coordinate \"<instructions>\" [--name <name>]
       cspace coordinate --prompt-file <path> [--name <name>]"
    fi
    if [ -n "$prompt" ] && [ -n "$prompt_file" ]; then
        die "Pass either an inline prompt or --prompt-file, not both"
    fi
    if [ -n "$prompt_file" ] && [ ! -f "$prompt_file" ]; then
        die "Prompt file not found: $prompt_file"
    fi

    load_config
    require_initialized

    if [ -z "$name" ]; then
        name="coord-$(date +%s)"
    fi

    # Provision the coordinator instance
    CSPACE_INSTANCE_NAME="$name" CSPACE_INSTANCE_BRANCH="" \
        bash "$(resolve_script setup-instance.sh)"

    skip_onboarding "$name"

    local DC="docker compose -p $name"

    # Re-copy host .env into container so the coordinator inherits GH_TOKEN, etc.
    if [ -f "$PROJECT_ROOT/.env" ]; then
        $DC cp "$PROJECT_ROOT/.env" devcontainer:/workspace/.env
        $DC exec -T devcontainer chown dev:dev /workspace/.env </dev/null
    fi

    # Build the full coordinator prompt: playbook + USER INSTRUCTIONS + body
    local playbook_file
    playbook_file=$(resolve_agent "coordinator.md")
    local user_body
    if [ -n "$prompt_file" ]; then
        user_body=$(cat "$prompt_file")
    else
        user_body="$prompt"
    fi

    local FULL_PROMPT
    FULL_PROMPT="$(cat "$playbook_file")"$'\n\nUSER INSTRUCTIONS:\n\n'"$user_body"

    # Stream the prompt into the container via stdin (no quoting concerns)
    printf '%s' "$FULL_PROMPT" | \
        $DC exec -T -u dev devcontainer bash -c 'cat > /tmp/coordinator-prompt.txt'

    local model effort
    model=$(cfg '.claude.model')
    effort=$(cfg '.claude.effort')

    local effort_flag system_prompt_flag
    effort_flag=$(build_effort_flag "$effort")
    system_prompt_flag=$(build_system_prompt_flag "$name" coordinator)

    # Launch the supervisor in coordinator role. Output streams to the
    # caller's terminal via stream-status.sh; the supervisor's Unix socket
    # is reachable for cspace send/respond/interrupt mid-run.
    launch_supervisor "$name" coordinator /tmp/coordinator-prompt.txt /tmp/coordinator-stderr.log "$effort_flag" "$system_prompt_flag"
}

cmd_ssh() {
    local name="${1:-}"
    [ -z "$name" ] && die "Usage: cspace ssh <name>"

    load_config
    require_running "$name"
    exec docker compose -p "$name" exec -u dev -w /workspace devcontainer bash
}

cmd_list() {
    local all=false
    [ "${1:-}" = "--all" ] && all=true

    load_config

    if [ "$all" = true ]; then
        local rows
        rows=$(get_all_instances)
        if [ -z "$rows" ]; then
            echo "(no instances found across any project)"
            return 0
        fi
        printf "%-16s %-20s %-30s %s\n" "INSTANCE" "PROJECT" "BRANCH" "AGE"
        printf "%-16s %-20s %-30s %s\n" "--------" "-------" "------" "---"
        get_all_instance_details
        echo ""
        echo "Run 'cspace ports <name>' for port mappings."
        return 0
    fi

    local projects
    projects=$(get_instances)
    if [ -z "$projects" ]; then
        echo "(no instances found for this project — try 'cspace list --all')"
        return 0
    fi

    printf "%-20s %-30s %s\n" "INSTANCE" "BRANCH" "AGE"
    printf "%-20s %-30s %s\n" "--------" "------" "---"
    get_instance_details
    echo ""
    echo "Run 'cspace ports <name>' for port mappings."
}

cmd_ports() {
    local name="${1:-}"
    [ -z "$name" ] && die "Usage: cspace ports <name>"

    load_config
    require_running "$name"
    show_ports "$name"
}

cmd_down() {
    if [ "${1:-}" = "--all" ]; then
        cmd_down_all
        return
    fi
    if [ "${1:-}" = "--everywhere" ]; then
        cmd_down_everywhere
        return
    fi

    local name="${1:-}"
    [ -z "$name" ] && die "Usage: cspace down <name> | --all | --everywhere"

    load_config
    dc_compose "$name" down --volumes
    echo "Instance '$name' removed."
}

cmd_down_all() {
    load_config

    local projects
    projects=$(get_instances)
    if [ -n "$projects" ]; then
        while read -r project; do
            [ -z "$project" ] && continue
            echo "Tearing down instance: $project"
            dc_compose "$project" down --volumes
        done <<< "$projects"
    else
        echo "No instances found for this project."
    fi
}

cmd_down_everywhere() {
    load_config

    local rows
    rows=$(get_all_instances)
    if [ -z "$rows" ]; then
        echo "No cspace instances running anywhere."
        return 0
    fi

    # Show what's about to be destroyed and confirm
    echo "About to tear down ALL cspace instances across ALL projects:"
    echo ""
    printf "  %-16s %-20s\n" "INSTANCE" "PROJECT"
    printf "  %-16s %-20s\n" "--------" "-------"
    echo "$rows" | while IFS=$'\t' read -r instance project; do
        printf "  %-16s %-20s\n" "$instance" "${project:-?}"
    done
    echo ""

    if command -v gum &>/dev/null; then
        gum confirm "Destroy all instances and their volumes?" || { echo "Aborted."; return 0; }
    else
        printf "Type 'yes' to continue: "
        read -r reply
        [ "$reply" = "yes" ] || { echo "Aborted."; return 0; }
    fi

    echo "$rows" | while IFS=$'\t' read -r instance _; do
        [ -z "$instance" ] && continue
        echo "Tearing down instance: $instance"
        docker compose -p "$instance" down --volumes 2>&1 | sed 's/^/  /'
    done

    echo "Done."
}

cmd_warm() {
    [ $# -eq 0 ] && die "Usage: cspace warm <name> [name...]"

    load_config
    require_initialized

    local names=("$@")
    local failed=0
    local results=()

    echo "Warming ${#names[@]} containers..."
    echo ""

    for name in "${names[@]}"; do
        echo "--- Setting up $name ---"

        if ! CSPACE_INSTANCE_NAME="$name" CSPACE_INSTANCE_BRANCH="" \
            bash "$(resolve_script setup-instance.sh)"; then
            echo "ERROR: setup failed for $name"
            results+=("$name|FAILED|setup failed")
            failed=$((failed + 1))
            continue
        fi

        skip_onboarding "$name"

        # Validate firewall
        if ! dc_exec_root "$name" test -f /tmp/.firewall-init-done 2>/dev/null; then
            echo "WARNING: Firewall not initialized — reinitializing..."
            if dc_exec_root "$name" init-firewall.sh 2>/dev/null; then
                dc_exec_root "$name" touch /tmp/.firewall-init-done
            else
                results+=("$name|FAILED|firewall init failed")
                failed=$((failed + 1))
                continue
            fi
        fi

        results+=("$name|ready")
        echo ""
    done

    # Summary
    echo "========================================="
    printf "%-20s %-10s\n" "INSTANCE" "STATUS"
    printf "%-20s %-10s\n" "--------" "------"
    for row in "${results[@]}"; do
        IFS='|' read -r rname rstatus _ <<< "$row"
        printf "%-20s %-10s\n" "$rname" "$rstatus"
    done

    if [ "$failed" -gt 0 ]; then
        echo "$failed container(s) failed validation."
        exit 1
    else
        echo "All ${#names[@]} containers ready."
    fi
}

cmd_rebuild() {
    load_config
    require_initialized

    local dockerfile
    dockerfile=$(resolve_template "Dockerfile")

    # Build context is the cspace repo root so the Dockerfile can COPY both
    # bin/cspace and lib/. Matches the context set in docker-compose.core.yml.
    docker build --no-cache -t "$(image_name)" -f "$dockerfile" "$CSPACE_HOME"
    echo "Image '$(image_name)' rebuilt."
}

cmd_sync_context() {
    load_config
    local script
    script=$(resolve_script "sync-context.sh")
    if [ -f "$script" ]; then
        bash "$script"
    else
        echo "No sync-context.sh found."
    fi
}

# ─── Supervisor dispatch ────────────────────────────────────────────
#
# All supervisor host-side commands run cli.mjs inside a running cspace
# container. The shared cspace-logs volume is mounted in every container,
# so any running instance can dispatch to any other instance's socket.

supervisor_dispatch() {
    load_config
    local target
    target=$(get_instances | head -1) || true
    [ -z "$target" ] && die "No running cspace instances. Start one with 'cspace up' first."
    docker compose -p "$target" exec -u dev -T devcontainer \
        node /opt/agent-supervisor/cli.mjs "$@"
}

supervisor_dispatch_interactive() {
    load_config
    local target
    target=$(get_instances | head -1) || true
    [ -z "$target" ] && die "No running cspace instances. Start one with 'cspace up' first."
    exec docker compose -p "$target" exec -u dev devcontainer \
        node /opt/agent-supervisor/cli.mjs "$@"
}

cmd_send() {
    [ $# -lt 2 ] && die "Usage: cspace send <instance> \"text\""
    supervisor_dispatch send "$@"
}

cmd_respond() {
    [ $# -lt 3 ] && die "Usage: cspace respond <instance> <question-id> \"text\""
    supervisor_dispatch respond "$@"
}

cmd_ask() {
    supervisor_dispatch list "$@"
}

cmd_watch() {
    supervisor_dispatch_interactive watch "$@"
}

cmd_interrupt() {
    [ $# -lt 1 ] && die "Usage: cspace interrupt <instance>"
    supervisor_dispatch interrupt "$@"
}

cmd_agent_status() {
    [ $# -lt 1 ] && die "Usage: cspace agent-status <instance>"
    supervisor_dispatch status "$@"
}

cmd_restart_supervisor() {
    local name="" reason=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --reason) reason="$2"; shift 2 ;;
            --*) die "Unknown flag: $1" ;;
            *)
                if [ -z "$name" ]; then
                    name="$1"
                fi
                shift
                ;;
        esac
    done

    [ -z "$name" ] && die "Usage: cspace restart-supervisor <instance> [--reason \"text\"]"

    load_config
    restart_supervisor "$name" "$reason"
}

cmd_self_update() {
    if [ -d "$CSPACE_HOME/.git" ]; then
        echo "Updating cspace..."
        git -C "$CSPACE_HOME" pull --ff-only
        echo "Updated to $(git -C "$CSPACE_HOME" describe --tags 2>/dev/null || git -C "$CSPACE_HOME" rev-parse --short HEAD)"
    else
        die "cspace was not installed via git clone. Cannot self-update."
    fi
}

cmd_tui() {
    load_config

    if ! command -v gum &>/dev/null; then
        die "TUI requires gum (https://github.com/charmbracelet/gum). Install it or use subcommands directly."
    fi

    local instances has_instances=false
    instances=$(get_instances)
    [ -n "$instances" ] && has_instances=true

    local options=()
    options+=("New instance        Launch a new Claude instance")
    if [ "$has_instances" = true ]; then
        options+=("Connect             Attach to a running instance")
        options+=("SSH                 Shell into an instance")
        options+=("Ports               Show port mappings")
        options+=("Down                Tear down an instance")
    fi
    options+=("Coordinate          Run a coordinator on a multi-task instruction")
    if [ "$has_instances" = true ]; then
        options+=("Down all            Tear down all instances")
        options+=("List                Show all running instances")
    fi
    options+=("Rebuild             Rebuild the container image")

    local project_display
    project_display=$(project_name 2>/dev/null || basename "$PWD")
    gum style --bold --border rounded --padding "0 1" --border-foreground 99 "cspace: $project_display"
    echo ""

    if [ "$has_instances" = true ]; then
        get_instance_details | while IFS= read -r line; do
            echo "  $line"
        done
        echo ""
    fi

    local choice
    choice=$(printf '%s\n' "${options[@]}" | gum choose --header "What do you want to do?") || exit 0

    case "$choice" in
        New*)        tui_new ;;
        Connect*)    tui_connect ;;
        SSH*)        local n; n=$(tui_pick_instance); cmd_ssh "$n" ;;
        Ports*)      local n; n=$(tui_pick_instance); cmd_ports "$n" ;;
        "Down all"*) cmd_down_all ;;
        Down*)       tui_down ;;
        Coordinate*) tui_coordinate ;;
        List*)       cmd_list ;;
        Rebuild*)    gum confirm "Rebuild the container image?" && cmd_rebuild ;;
    esac
}

tui_pick_instance() {
    local instances
    instances=$(get_instances)
    [ -z "$instances" ] && { gum style --foreground 208 "No running instances."; exit 0; }

    local details header selected
    details=$(get_instance_details)
    header=$(printf "%-16s %-30s %s" "INSTANCE" "BRANCH" "AGE")
    selected=$(echo "$details" | gum choose --header "$header") || exit 0
    echo "$selected" | awk '{print $1}'
}

tui_new() {
    local name
    name=$(gum input --placeholder "Instance name (leave empty for auto planet name)") || exit 0
    if [ -z "$name" ]; then
        cmd_up
    else
        cmd_up "$name"
    fi
}

tui_connect() {
    local name
    name=$(tui_pick_instance)
    local action
    action=$(gum choose --header "Connect to $name" \
        "Claude       Open Claude Code" \
        "SSH          Shell into container" \
        "Ports        Show port mappings") || exit 0

    case "$(echo "$action" | awk '{print tolower($1)}')" in
        claude) cmd_up "$name" ;;
        ssh)    cmd_ssh "$name" ;;
        ports)  cmd_ports "$name" ;;
    esac
}

tui_down() {
    local name
    name=$(tui_pick_instance)
    gum confirm "Tear down instance '$name' and delete its volumes?" || exit 0
    cmd_down "$name"
    gum style --foreground 78 "Instance '$name' removed."
}

tui_coordinate() {
    local prompt
    prompt=$(gum write --placeholder "What should the coordinator do? (Ctrl+D to submit)" --width 80 --height 10) || exit 0
    [ -z "$prompt" ] && die "Prompt required."

    local name
    name=$(gum input --placeholder "Instance name (leave empty to auto-generate)") || exit 0
    if [ -z "$name" ]; then
        cmd_coordinate "$prompt"
    else
        cmd_coordinate "$prompt" --name "$name"
    fi
}

# ─── Main Dispatch ──────────────────────────────────────────────────

case "${1:-}" in
    "")             cmd_tui ;;
    help|--help|-h) usage ;;
    version|--version|-v) cmd_version ;;
    init)           shift; cmd_init "$@" ;;
    up)             shift; cmd_up "$@" ;;
    coordinate)     shift; cmd_coordinate "$@" ;;
    ssh)            shift; cmd_ssh "$@" ;;
    list|ls)        shift; cmd_list "$@" ;;
    ports)          shift; cmd_ports "$@" ;;
    down)           shift; cmd_down "$@" ;;
    warm)           shift; cmd_warm "$@" ;;
    rebuild)        cmd_rebuild ;;
    send)           shift; cmd_send "$@" ;;
    respond)        shift; cmd_respond "$@" ;;
    ask)            shift; cmd_ask "$@" ;;
    watch)          shift; cmd_watch "$@" ;;
    interrupt)      shift; cmd_interrupt "$@" ;;
    agent-status)   shift; cmd_agent_status "$@" ;;
    restart-supervisor) shift; cmd_restart_supervisor "$@" ;;
    sync-context)   cmd_sync_context ;;
    self-update)    cmd_self_update ;;
    *)              die "Unknown command: $1. Run 'cspace help' for usage." ;;
esac
