{
  "project": {
    "name": "my-project",
    "repo": "owner/my-project",
    "prefix": "mp"
  },
  "container": {
    "ports": {
      "3000": "dev server",
      "4173": "preview server"
    },
    "environment": {
      "VITE_HOST": "0.0.0.0"
    }
  },
  "firewall": {
    "enabled": true,
    "domains": [
      "api.example.com",
      "cdn.example.com"
    ]
  },
  "verify": {
    "all": "npm run lint && npm run typecheck && npm run test",
    "e2e": "npm run e2e"
  },
  "agent": {
    "issue_label": "ready"
  },
  "services": {
    "convex": {
      "image": "ghcr.io/get-convex/convex-backend:latest",
      "publish_port": 3210,
      "healthcheck": { "path": "/version", "timeout_seconds": 30 },
      "extract_credentials": {
        "command": ["/generate_admin_key.sh"],
        "env_var": "ADMIN_KEY"
      }
    }
  },
  "post_setup": ".cspace/post-setup.sh"
}
